PORT=3000

# Bitbucket Cloud
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_TOKEN=your_bitbucket_access_token
BITBUCKET_WEBHOOK_SECRET=replace_with_a_random_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Behavior
MAX_DIFF_CHARS=120000
POST_INLINE_COMMENTS=false
POST_SUMMARY_COMMENT=true
POST_BUILD_STATUS=false
BOT_TAG=ai-review-bot
MIN_INLINE_CONFIDENCE=0.8
